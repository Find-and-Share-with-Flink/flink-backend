root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.java]
indent_style = space
indent_size = 4

[*.{yml,yaml,md}]
indent_style = space
indent_size = 2

[*.{gradle,json,js,ts}]
indent_style = space
indent_size = 2

[*.properties]
charset = utf-8
indent_style = space
indent_size = 2
